# Gambit — Environment Variables
# Copy this file to .env.local and fill in your values.

# Privy (wallet connection)
# Get your app ID free at https://privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Aomi Backend
# Staging (where Gambit is live): https://staging-api.aomi.dev
# Production: https://api.aomi.dev
NEXT_PUBLIC_AOMI_BACKEND_URL=https://staging-api.aomi.dev

# Limitless API (configured as Aomi app secrets, not needed in frontend)
# LIMITLESS_API_KEY=your_limitless_api_key
# LIMITLESS_API_SECRET=your_limitless_api_secret
