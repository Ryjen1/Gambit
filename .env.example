# Gambit — Environment Variables
# Copy this file to .env.local and fill in your values.

# Aomi Configuration
# Get your API key from https://aomi.dev after creating your app
NEXT_PUBLIC_AOMI_APP_SLUG=gambit
NEXT_PUBLIC_AOMI_API_KEY=your_aomi_api_key_here
NEXT_PUBLIC_AOMI_API_URL=https://api.aomi.dev

# Limitless API (configured as Aomi app secrets, not needed in frontend)
# LIMITLESS_API_KEY=your_limitless_api_key
# LIMITLESS_API_SECRET=your_limitless_api_secret
